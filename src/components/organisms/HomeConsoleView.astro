---
import type { Post } from "../../lib/types";
import type { Lang } from "../../i18n/i18n";
import type { SourceHealthSummary } from "../../lib/metrics";
import type { Category } from "../../lib/categories";
import SpotlightGrid from "./SpotlightGrid.astro";
import SignalBoard from "./SignalBoard.astro";
import PostList from "./PostList.astro";
import PreferencesDrawer from "./PreferencesDrawer.astro";
import CategoryIcon from "../atoms/CategoryIcon.astro";
import Chip from "../atoms/Chip.astro";
import Icon from "../atoms/Icon.astro";
import SourceBadge from "../molecules/SourceBadge.astro";
import { CATEGORIES, categoryLabel } from "../../lib/categories";
import { getCategoryTheme } from "../../lib/category-theme";
import { href } from "../../lib/href";
import { t } from "../../i18n/i18n";
import { resolveCover } from "../../lib/cover";
import { formatRelativeHours } from "../../lib/format";

export type Props = {
  lang: Lang;
  latest: Post[];
  spotlight: Post[];
  pulseTop: Post[];
  hotTags: Array<{ tag: string; count: number }>;
  lensCounts: Record<"2h" | "6h" | "24h", number>;
  healthSummary: SourceHealthSummary;
  updatedAt: string;
  enrichedCount: number;
  stableRatio: number;
  topPulse: number;
  brief: Post[];
  randomPick: Post | null;
  randomPickCover: { src: string; original?: string } | null;
  randomPickCoverOriginal?: string;
  showRandomPickCover: boolean;
  categoryCount: Map<Category, number>;
};

const {
  lang,
  latest,
  spotlight,
  pulseTop,
  hotTags,
  lensCounts,
  healthSummary,
  updatedAt,
  enrichedCount,
  stableRatio,
  topPulse,
  brief,
  randomPick,
  randomPickCover,
  randomPickCoverOriginal,
  categoryCount
} = Astro.props as Props;

const heroFeature = spotlight[0] ?? latest[0] ?? randomPick;
const heroTitle = heroFeature
  ? lang === "zh"
    ? (heroFeature.titleZh ?? heroFeature.title)
    : (heroFeature.titleJa ?? heroFeature.title)
  : null;
const heroSummary = heroFeature
  ? lang === "zh"
    ? (heroFeature.summaryZh ?? heroFeature.previewZh ?? heroFeature.summary ?? heroFeature.preview)
    : (heroFeature.summaryJa ?? heroFeature.previewJa ?? heroFeature.summary ?? heroFeature.preview)
  : null;
const heroCover = heroFeature ? resolveCover(heroFeature.cover, 1600) : randomPickCover;
const heroCoverOriginal = heroFeature?.coverOriginal ?? heroCover?.original ?? randomPickCoverOriginal;
const heroHref = heroFeature ? href(`/${lang}/p/${heroFeature.id}/`) : href(`/${lang}/`);
const heroWhen = heroFeature ? (formatRelativeHours(lang, heroFeature.publishedAt) ?? updatedAt) : updatedAt;
const heroPulse = typeof heroFeature?.pulseScore === "number" ? heroFeature.pulseScore : topPulse;
const heroSourceName = heroFeature?.sourceName ?? "ACG Radar";
const heroCategory = heroFeature?.category ?? CATEGORIES[0];
const heroTheme = getCategoryTheme(heroCategory);

const secondaryFeature = (() => {
  const pool = [randomPick, spotlight[1], latest[1], latest[2]].filter((post): post is Post => Boolean(post));
  return pool.find((post) => post.id !== heroFeature?.id) ?? null;
})();
const secondaryCover = secondaryFeature ? resolveCover(secondaryFeature.cover, 1200) : null;
const secondaryTitle = secondaryFeature
  ? lang === "zh"
    ? (secondaryFeature.titleZh ?? secondaryFeature.title)
    : (secondaryFeature.titleJa ?? secondaryFeature.title)
  : null;
const secondaryTheme = secondaryFeature ? getCategoryTheme(secondaryFeature.category) : null;
const copyBriefText = brief
  .map(
    (post, index) =>
      `${index + 1}. ${lang === "zh" ? (post.titleZh ?? post.title) : (post.titleJa ?? post.title)}`
  )
  .join("\n");

const labels = {
  zh: {
    kicker: "编辑部选题",
    headline: "今天值得先看的内容",
    lead: "把新番、联动、舞台消息和周边动态重新排成一张像样的首页封面：先有主角内容，再有追更入口，而不是把一切挤成同一个层级。",
    mission: "版面说明",
    missionBody: "主视觉先负责题材和情绪，精选与列表再承担密度和追更；这更像二次元媒体首页，而不是后台面板。",
    missionHint: "首页封面 · 每小时更新 · 双语镜像",
    statusLive: "今日焦点",
    statusWatch: "EDITOR'S PICK",
    latestFeed: "最新条目",
    latestHint: "最新内容仍然保持高信息密度，但第一页先展示真正值得点开的主角位与专题位。",
    categories: "今日栏目",
    categoriesHint: "按类别直接进入对应波段。",
    briefTitle: "五条快讯",
    briefHint: "像媒体首页右侧的快讯栏，而不是另一组碎卡片。",
    randomTitle: "顺手一看",
    randomHint: "作为次级推荐出现，不再抢走主视觉焦点。",
    openSignal: "打开信号",
    searchScope: "全局检索",
    searchSub: "支持关键词 / 标签 / 来源联动",
    spotlight: "编辑精选",
    spotlightHint: "把最值得点开的内容抬到画面中央，而不是混在普通流里。",
    emptyTitle: "当前筛选下暂无信号",
    emptyHint: "你可以清空搜索词或关闭部分过滤条件。",
    heroLabel: "本轮主角"
  },
  ja: {
    kicker: "EDITORIAL DESK",
    headline: "きょう最初に見るべき話題",
    lead: "新作アニメ、ゲーム連動、ステージ情報、グッズ展開を“ちゃんと一枚の表紙”として並べ直します。全部を同じ重さで詰め込まないためのトップページです。",
    mission: "LAYOUT NOTE",
    missionBody:
      "主ビジュアルで空気を作り、ピックアップと一覧で追いかける。ダッシュボードではなく、ACG メディアの表紙に寄せています。",
    missionHint: "Front cover · Hourly sync · Bilingual mirror",
    statusLive: "TODAY'S LEAD",
    statusWatch: "EDITOR'S PICK",
    latestFeed: "LATEST ENTRIES",
    latestHint: "更新密度は保ちながら、最初の視線は主役記事と特集枠に集めます。",
    categories: "TODAY'S DESKS",
    categoriesHint: "カテゴリごとの波長へ直接アクセス。",
    briefTitle: "FIVE BRIEFS",
    briefHint: "別の小カード群ではなく、編集部の速報欄として配置。",
    randomTitle: "SIDE PICK",
    randomHint: "主役ではなく、次点の推薦として配置します。",
    openSignal: "OPEN SIGNAL",
    searchScope: "GLOBAL SEARCH",
    searchSub: "キーワード / タグ / ソース連動検索",
    spotlight: "CURATED STORIES",
    spotlightHint: "最も見せたい内容を中央へ引き上げ、通常の一覧とは別の重みで扱います。",
    emptyTitle: "この条件ではシグナルがありません",
    emptyHint: "検索語を消すか、フィルター条件を少し緩めてください。",
    heroLabel: "MAIN FOCUS"
  }
}[lang];
---

<section class="acg-console-home">
  <div class="acg-console-canvas glass">
    <section class="acg-console-canvas-section acg-console-canvas-hero">
      <div class="acg-console-feature-stage">
        <div class="acg-console-feature-copy">
          <div class="acg-console-kicker-row">
            <span class="acg-console-kicker">{labels.kicker}</span>
            <span class="acg-console-status-pill">{labels.statusWatch}</span>
          </div>

          <div class="space-y-3">
            <h1 class="acg-console-title">{t(lang, "nav.latest")} · {labels.headline}</h1>
            <p class="acg-console-copy">{labels.lead}</p>
          </div>

          <div class="acg-console-meta-grid">
            <div class="acg-console-meta-card">
              <span class="acg-console-meta-label">{t(lang, "common.updatedAt")}</span>
              <strong>{updatedAt}</strong>
            </div>
            <div class="acg-console-meta-card">
              <span class="acg-console-meta-label">{labels.statusLive}</span>
              <strong>{enrichedCount}</strong>
            </div>
            <div class="acg-console-meta-card">
              <span class="acg-console-meta-label">{t(lang, "home.stableSources")}</span>
              <strong>{stableRatio}%</strong>
            </div>
            <div class="acg-console-meta-card">
              <span class="acg-console-meta-label">{t(lang, "prefs.sortPulse")}</span>
              <strong>{topPulse}</strong>
            </div>
          </div>

          <div class="acg-console-search-wrap">
            <div class="acg-console-search-head">
              <div>
                <div class="acg-console-search-label">{labels.searchScope}</div>
                <div class="acg-console-search-sub">{labels.searchSub}</div>
              </div>
              <div class="flex flex-wrap items-center gap-2 text-xs text-slate-200/72">
                <span class="acg-console-inline-pill">
                  {t(lang, "search.result")}
                  <span id="acg-search-count">-</span>
                </span>
                <span class="acg-console-inline-pill">
                  {t(lang, "home.unread")}
                  <span id="acg-unread-count">-</span>
                </span>
              </div>
            </div>
            <label class="sr-only" for="acg-search">{t(lang, "search.placeholder")}</label>
            <div class="acg-console-search-field">
              <div class="acg-console-search-icon">
                <Icon name="search" size={18} />
              </div>
              <input
                id="acg-search"
                type="search"
                enterkeyhint="search"
                class="acg-console-input"
                placeholder={t(lang, "search.placeholder")}
              />
              <button
                type="button"
                id="acg-search-clear"
                class="acg-console-clear clickable"
                hidden
                aria-label={t(lang, "search.clear")}
                title={t(lang, "search.clear")}
              >
                <Icon name="x" size={18} />
              </button>
            </div>
          </div>

          <div class="acg-console-kpi-grid">
            <button type="button" class="acg-console-kpi clickable" data-quick-lens="2h" data-active="false">
              <span class="acg-console-kpi-label">{t(lang, "prefs.timeLens2h")}</span>
              <span class="acg-console-kpi-value">{lensCounts["2h"]}</span>
            </button>
            <button type="button" class="acg-console-kpi clickable" data-quick-lens="24h" data-active="false">
              <span class="acg-console-kpi-label">{t(lang, "prefs.timeLens24h")}</span>
              <span class="acg-console-kpi-value">{lensCounts["24h"]}</span>
            </button>
            <button
              type="button"
              class="acg-console-kpi clickable"
              data-quick-sort="pulse"
              data-active="false"
            >
              <span class="acg-console-kpi-label">{t(lang, "prefs.sortPulse")}</span>
              <span class="acg-console-kpi-value">{topPulse}</span>
            </button>
            <button
              type="button"
              class="acg-console-kpi clickable"
              data-quick-toggle="only-stable"
              data-active="false"
            >
              <span class="acg-console-kpi-label">{t(lang, "home.stableSources")}</span>
              <span class="acg-console-kpi-value">{stableRatio}%</span>
            </button>
          </div>
        </div>

        <div class="acg-console-feature-visual">
          <div class="acg-console-side-note acg-console-side-note-tight">
            <div class="acg-console-side-head">
              <span>{labels.mission}</span>
              <span>{labels.missionHint}</span>
            </div>
            <p>{labels.missionBody}</p>
          </div>

          <a href={heroHref} class="acg-console-feature-card clickable group" data-genre={heroCategory}>
            <div class="acg-console-feature-media">
              {
                heroCover ? (
                  <img
                    src={heroCover.src}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                    data-acg-cover
                    data-acg-cover-original-src={heroCoverOriginal ?? ""}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                    onload="window.__acgCoverLoad?.(this)"
                    onerror="this.closest('[data-feature-card]')?.classList.add('cover-failed'); this.style.opacity='0'; this.style.pointerEvents='none'; window.__acgCoverError?.(this)"
                  />
                ) : null
              }
              <div data-feature-card class="acg-console-feature-fallback">
                <CategoryIcon category={heroCategory} size={28} />
                <span>{categoryLabel(lang, heroCategory)}</span>
              </div>
              <div class="acg-console-feature-overlay"></div>
            </div>
            <div class="acg-console-feature-content">
              <div class="acg-console-kicker-row">
                <span class="acg-console-inline-pill">
                  {heroTheme[lang === "zh" ? "featureLabelZh" : "featureLabelJa"]}
                </span>
                <span class="acg-console-inline-pill">{heroWhen}</span>
                {heroPulse ? <span class="acg-console-inline-pill">PULSE {heroPulse}</span> : null}
              </div>
              <h2 class="acg-console-feature-title">{heroTitle ?? t(lang, "site.name")}</h2>
              <p class="acg-console-feature-summary">{heroSummary ?? labels.openSignal}</p>
              <div class="acg-console-feature-footer">
                <SourceBadge name={heroSourceName} dotClass="bg-white" tone="dark" compact />
                <span class="acg-console-feature-mood">
                  {heroTheme[lang === "zh" ? "moodZh" : "moodJa"]}
                </span>
                <span class="acg-console-linkline">
                  {labels.openSignal}
                  <Icon name="chevron-right" size={16} />
                </span>
              </div>
            </div>
          </a>
        </div>
      </div>

      <div class="acg-console-toolbar acg-hscroll mt-5">
        <Chip data-quick-toggle="only-followed" data-active="false">{t(lang, "prefs.followOnly")}</Chip>
        <Chip data-quick-toggle="only-followed-sources" data-active="false">
          {t(lang, "prefs.followedSourcesOnly")}
        </Chip>
        <Chip data-quick-toggle="hide-read" data-active="false">{t(lang, "prefs.hideRead")}</Chip>
        <Chip data-quick-toggle="only-stable" data-active="false">{t(lang, "prefs.onlyStableSources")}</Chip>
        <Chip data-quick-toggle="dedup" data-active="false">{t(lang, "prefs.dedupView")}</Chip>
        <div class="flex gap-2" role="radiogroup" aria-label={t(lang, "prefs.view")}>
          <Chip
            icon="grid"
            iconSize={16}
            data-view-mode="grid"
            data-active="false"
            role="radio"
            aria-checked="false"
          >
            <span>{t(lang, "prefs.viewGrid")}</span>
          </Chip>
          <Chip
            icon="list"
            iconSize={16}
            data-view-mode="list"
            data-active="false"
            role="radio"
            aria-checked="false"
          >
            <span>{t(lang, "prefs.viewList")}</span>
          </Chip>
        </div>
        <div class="flex gap-2" role="radiogroup" aria-label={t(lang, "prefs.density")}>
          <Chip data-density-mode="comfort" data-active="false" role="radio" aria-checked="false">
            {t(lang, "prefs.densityComfort")}
          </Chip>
          <Chip data-density-mode="compact" data-active="false" role="radio" aria-checked="false">
            {t(lang, "prefs.densityCompact")}
          </Chip>
        </div>
        <Chip data-quick-lens="6h" data-active="false">{t(lang, "prefs.timeLens6h")}</Chip>
        <Chip icon="sliders" iconSize={16} data-open-prefs data-active="false">
          <span>{t(lang, "prefs.title")}</span>
        </Chip>
      </div>

      <div class="acg-console-inline-grid mt-5">
        <div class="acg-console-inline-panel">
          <div class="acg-console-panel-head">
            <div>
              <h2>{labels.categories}</h2>
              <p>{labels.categoriesHint}</p>
            </div>
          </div>
          <div class="acg-console-category-grid acg-console-category-grid-tight">
            {
              CATEGORIES.map((category) => (
                <a href={href(`/${lang}/c/${category}/`)} class="acg-console-category-card clickable">
                  <span class="acg-console-category-icon">
                    <CategoryIcon category={category} size={18} />
                  </span>
                  <span class="min-w-0 flex-1">
                    <strong>{categoryLabel(lang, category)}</strong>
                    <small>{categoryCount.get(category) ?? 0}</small>
                  </span>
                  <Icon name="chevron-right" size={16} />
                </a>
              ))
            }
          </div>
        </div>

        <div class="acg-console-inline-panel">
          <div class="acg-console-panel-head">
            <div>
              <h2>{labels.briefTitle}</h2>
              <p>{labels.briefHint}</p>
            </div>
            <button
              type="button"
              class="acg-console-ghost clickable"
              data-copy-text={copyBriefText}
              aria-label={t(lang, "home.copyBrief")}
              title={t(lang, "home.copyBrief")}
            >
              {t(lang, "home.copyBrief")}
            </button>
          </div>
          <ol class="acg-console-log-list acg-console-log-list-compact">
            {
              brief.slice(0, 5).map((post, index) => (
                <li>
                  <a href={href(`/${lang}/p/${post.id}/`)} class="acg-console-log-item clickable">
                    <span class="acg-console-log-rank">{String(index + 1).padStart(2, "0")}</span>
                    <span class="min-w-0 flex-1 truncate">
                      {lang === "zh" ? (post.titleZh ?? post.title) : (post.titleJa ?? post.title)}
                    </span>
                    <Icon name="chevron-right" size={16} />
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <div class="acg-console-canvas-divider"></div>

    <section class="acg-console-canvas-section">
      <div class="acg-console-section-head">
        <div>
          <span class="acg-console-eyebrow">{labels.spotlight}</span>
          <h2>{t(lang, "home.spotlight")}</h2>
        </div>
        <p>{labels.spotlightHint}</p>
      </div>
      <div class="acg-console-module mt-4">
        <SpotlightGrid posts={spotlight} lang={lang} title={t(lang, "home.spotlight")} />
      </div>
    </section>

    <div class="acg-console-canvas-divider"></div>

    <section class="acg-console-canvas-section">
      <div class="acg-console-feed-layout">
        <div class="acg-console-feed space-y-4">
          <div class="acg-console-section-head">
            <div>
              <span class="acg-console-eyebrow">{labels.statusLive}</span>
              <h2>{labels.latestFeed}</h2>
            </div>
            <p>{labels.latestHint}</p>
          </div>
          <PostList posts={latest} lang={lang} />
          <div id="acg-list-empty" class="acg-console-empty glass hidden">
            <div class="radar grid size-16 place-items-center shadow-e4">
              <span class="text-sm font-bold text-white/90">?</span>
            </div>
            <div>
              <div class="text-sm font-semibold text-slate-50">{labels.emptyTitle}</div>
              <div class="mt-2 text-xs leading-relaxed text-slate-300/72">{labels.emptyHint}</div>
            </div>
            <button type="button" id="acg-clear-search" class="acg-console-primary clickable">
              {t(lang, "search.clear")}
            </button>
          </div>
        </div>

        <aside class="acg-console-stack">
          <div class="acg-console-module">
            <SignalBoard
              lang={lang}
              pulseTop={pulseTop}
              hotTags={hotTags}
              lensCounts={lensCounts}
              healthSummary={healthSummary}
              totalPosts={enrichedCount}
            />
          </div>

          <section class="acg-console-inline-panel acg-console-random-panel">
            <div class="acg-console-panel-head">
              <div>
                <h2>{labels.randomTitle}</h2>
                <p>{labels.randomHint}</p>
              </div>
            </div>
            {
              secondaryFeature ? (
                <a
                  href={href(`/${lang}/p/${secondaryFeature.id}/`)}
                  class="acg-console-random-card clickable group"
                  data-genre={secondaryFeature.category}
                >
                  <div class="acg-console-random-media">
                    {secondaryCover ? (
                      <img
                        src={secondaryCover.src}
                        alt=""
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                        data-acg-cover
                        data-acg-cover-original-src={
                          secondaryFeature.coverOriginal ?? secondaryCover.original ?? ""
                        }
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                        onload="window.__acgCoverLoad?.(this)"
                        onerror="this.closest('[data-random-card]')?.classList.add('cover-failed'); this.style.opacity='0'; this.style.pointerEvents='none'; window.__acgCoverError?.(this)"
                      />
                    ) : (
                      <div class="acg-console-random-fallback">
                        <CategoryIcon category={secondaryFeature.category} size={26} />
                        <span>{categoryLabel(lang, secondaryFeature.category)}</span>
                      </div>
                    )}
                  </div>
                  <div data-random-card class="space-y-3">
                    <span class="acg-console-inline-pill">
                      {secondaryTheme?.[lang === "zh" ? "featureLabelZh" : "featureLabelJa"] ??
                        categoryLabel(lang, secondaryFeature.category)}
                    </span>
                    <div class="space-y-2">
                      <h3 class="acg-console-random-title">{secondaryTitle}</h3>
                      <p class="acg-console-random-copy">
                        {lang === "zh"
                          ? (secondaryFeature.summaryZh ??
                            secondaryFeature.previewZh ??
                            secondaryFeature.summary ??
                            secondaryFeature.preview ??
                            labels.randomHint)
                          : (secondaryFeature.summaryJa ??
                            secondaryFeature.previewJa ??
                            secondaryFeature.summary ??
                            secondaryFeature.preview ??
                            labels.randomHint)}
                      </p>
                    </div>
                    <span class="acg-console-linkline">
                      {labels.openSignal}
                      <Icon name="chevron-right" size={16} />
                    </span>
                  </div>
                </a>
              ) : (
                <p class="text-sm text-slate-300/72">{t(lang, "common.noData")}</p>
              )
            }
          </section>
        </aside>
      </div>
    </section>
  </div>

  <PreferencesDrawer lang={lang} />
</section>
