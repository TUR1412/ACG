---
import SiteLayout from "../../layouts/SiteLayout.astro";
import HomeConsoleView from "../../components/organisms/HomeConsoleView.astro";
import { readGeneratedPosts, readGeneratedStatus } from "../../lib/generated-data";
import { CATEGORIES, type Category } from "../../lib/categories";
import { formatDateTime } from "../../lib/format";
import { resolveCover } from "../../lib/cover";
import {
  applyDerivedMetrics,
  buildSourceHealthMap,
  computeTimeLensCounts,
  summarizeSourceHealth
} from "../../lib/metrics";

const posts = await readGeneratedPosts();
const status = await readGeneratedStatus();
const healthMap = buildSourceHealthMap(status.sources ?? []);
const enriched = applyDerivedMetrics(posts, healthMap);

const latest = enriched.slice(0, 24);
const updatedAt = status.generatedAt ? formatDateTime("zh", status.generatedAt) : "-";
const cutoff24h = Date.now() - 24 * 60 * 60 * 1000;
const recent24h = enriched.filter((post) => new Date(post.publishedAt).getTime() >= cutoff24h);

const tagCount = new Map<string, number>();
for (const post of recent24h) {
  for (const tag of post.tags ?? []) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
}
const hotTags = [...tagCount.entries()]
  .sort((left, right) => right[1] - left[1])
  .slice(0, 12)
  .map(([tag, count]) => ({ tag, count }));

const lensCounts = computeTimeLensCounts(enriched);
const healthSummary = summarizeSourceHealth(status.sources ?? [], healthMap);

const categoryCount = new Map<Category, number>();
for (const category of CATEGORIES) categoryCount.set(category, 0);
for (const post of recent24h) {
  categoryCount.set(post.category, (categoryCount.get(post.category) ?? 0) + 1);
}

const brief = recent24h.slice(0, 10);
const randomPick =
  enriched.length > 0 ? enriched[Math.floor(Math.random() * Math.min(200, enriched.length))] : null;
const randomPickCover = resolveCover(randomPick?.cover, 960);
const randomPickCoverOriginal = randomPick?.coverOriginal ?? randomPickCover?.original;
const showRandomPickCover = Boolean(randomPickCover && !/^https?:\/\//i.test(randomPickCover.src));

const pulseTop = [...recent24h]
  .sort((left, right) => (right.pulseScore ?? 0) - (left.pulseScore ?? 0))
  .slice(0, 6);
const stableRatio =
  healthSummary.total > 0 ? Math.round((healthSummary.stable / healthSummary.total) * 100) : 0;
const topPulse = typeof pulseTop[0]?.pulseScore === "number" ? pulseTop[0]!.pulseScore : 0;

const spotlight = (() => {
  const byPulse = (left: (typeof recent24h)[number], right: (typeof recent24h)[number]) =>
    (right.pulseScore ?? 0) - (left.pulseScore ?? 0);
  const withCover = recent24h.filter((post) => Boolean(post.cover)).sort(byPulse);
  const used = new Set(withCover.map((post) => post.id));
  const rest = recent24h.filter((post) => !used.has(post.id)).sort(byPulse);
  return [...withCover, ...rest].slice(0, 6);
})();
---

<SiteLayout lang="zh" currentPath="/">
  <HomeConsoleView
    lang="zh"
    latest={latest}
    spotlight={spotlight}
    pulseTop={pulseTop}
    hotTags={hotTags}
    lensCounts={lensCounts}
    healthSummary={healthSummary}
    updatedAt={updatedAt}
    enrichedCount={enriched.length}
    stableRatio={stableRatio}
    topPulse={topPulse}
    brief={brief}
    randomPick={randomPick}
    randomPickCover={randomPickCover}
    randomPickCoverOriginal={randomPickCoverOriginal}
    showRandomPickCover={showRandomPickCover}
    categoryCount={categoryCount}
  />
</SiteLayout>
