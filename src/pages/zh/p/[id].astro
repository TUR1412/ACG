---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import PostDetailConsoleView from "../../../components/organisms/PostDetailConsoleView.astro";
import type { Post } from "../../../lib/types";
import { readGeneratedPosts } from "../../../lib/generated-data";
import { getCategoryTheme } from "../../../lib/category-theme";
import { formatDateTime } from "../../../lib/format";
import { href } from "../../../lib/href";
import { createRecommender } from "../../../lib/recommend";
import { resolveCover } from "../../../lib/cover";
import { safeExternalHttpUrl } from "../../../lib/safe-url";

export async function getStaticPaths() {
  const posts = await readGeneratedPosts();
  const recommender = createRecommender(posts);
  return posts.map((post) => {
    const { newer, older } = recommender.getAdjacent(post);
    const related = recommender.getRelated(post, 6);
    return { params: { id: post.id }, props: { post, newer, older, related } };
  });
}

const { post, newer, older, related } = Astro.props as {
  post: Post;
  newer?: Post;
  older?: Post;
  related?: Post[];
};
const theme = getCategoryTheme(post.category);
const title = post.titleZh ?? post.title;
const summary = post.summaryZh ?? post.summary;
const preview = post.previewZh ?? post.preview;
const primaryText = summary ?? preview;
const extraPreview = summary && preview && preview !== summary ? preview : undefined;
const previewOpen = (summary?.length ?? 0) < 90;
const published = formatDateTime("zh", post.publishedAt);
const retryCoverLabel = "重试封面";
const cover = resolveCover(post.cover, 1400);
const coverOriginal = post.coverOriginal ?? cover?.original;
const ogImage = cover ? (Astro.site ? new URL(cover.src, Astro.site).toString() : cover.src) : undefined;
const publishedAtMs = new Date(post.publishedAt).getTime();
const isFresh =
  Number.isFinite(publishedAtMs) &&
  Date.now() - publishedAtMs >= 0 &&
  Date.now() - publishedAtMs < 6 * 60 * 60 * 1000;
const freshLabel = "NEW";
const pageUrl = Astro.site
  ? new URL(href(`/zh/p/${post.id}/`), Astro.site).toString()
  : href(`/zh/p/${post.id}/`);
const safeSourceUrl = safeExternalHttpUrl(post.url);
---

<SiteLayout
  lang="zh"
  title={title}
  description={primaryText ?? undefined}
  ogType="article"
  ogImage={ogImage}
  currentPath={`/p/${post.id}/`}
  currentPostId={post.id}
>
  <PostDetailConsoleView
    lang="zh"
    post={post}
    newer={newer}
    older={older}
    related={related}
    theme={theme}
    title={title}
    published={published}
    primaryText={primaryText}
    extraPreview={extraPreview}
    previewOpen={previewOpen}
    cover={cover}
    coverOriginal={coverOriginal}
    retryCoverLabel={retryCoverLabel}
    isFresh={isFresh}
    freshLabel={freshLabel}
    pageUrl={pageUrl}
    safeSourceUrl={safeSourceUrl}
  />
</SiteLayout>
