---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import CategoryConsoleView from "../../../components/organisms/CategoryConsoleView.astro";
import { readGeneratedPosts, readGeneratedStatus } from "../../../lib/generated-data";
import { CATEGORIES, type Category, categoryLabel } from "../../../lib/categories";
import { buildSourceHealthMap, applyDerivedMetrics, computeTimeLensCounts } from "../../../lib/metrics";

export function getStaticPaths() {
  return CATEGORIES.map((category) => ({ params: { category } }));
}

const posts = await readGeneratedPosts();
const status = await readGeneratedStatus();
const healthMap = buildSourceHealthMap(status.sources ?? []);
const enriched = applyDerivedMetrics(posts, healthMap);
const category = Astro.params.category as Category;
const inCategory = enriched.filter((post) => post.category === category);
const total = inCategory.length;
const filtered = inCategory.slice(0, 36);
const lensCounts = computeTimeLensCounts(inCategory);
const topPulse = inCategory.reduce(
  (max, post) => Math.max(max, typeof post.pulseScore === "number" ? post.pulseScore : 0),
  0
);
const sourceIds = new Set(inCategory.map((post) => post.sourceId).filter((id): id is string => Boolean(id)));
const stableSources = [...sourceIds].filter((id) => {
  const level = healthMap.get(id)?.level;
  return level === "excellent" || level === "good";
}).length;
const stableRatio = sourceIds.size > 0 ? Math.round((stableSources / sourceIds.size) * 100) : 0;
---

<SiteLayout
  lang="zh"
  title={categoryLabel("zh", category)}
  currentCategory={category}
  currentPath={`/c/${category}/`}
>
  <CategoryConsoleView
    lang="zh"
    category={category}
    filtered={filtered}
    total={total}
    lensCounts={lensCounts}
    topPulse={topPulse}
    stableRatio={stableRatio}
  />
</SiteLayout>
