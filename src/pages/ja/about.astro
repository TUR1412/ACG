---
import SiteLayout from "../../layouts/SiteLayout.astro";
import AboutConsoleView from "../../components/organisms/AboutConsoleView.astro";
import { readGeneratedStatus } from "../../lib/generated-data";
import { formatDateTime } from "../../lib/format";
import { SOURCE_CONFIGS } from "../../lib/source-config";
import { safeExternalHttpUrl } from "../../lib/safe-url";
import { t } from "../../i18n/i18n";

const status = await readGeneratedStatus();
const updatedAt = status.generatedAt ? formatDateTime("ja", status.generatedAt) : "-";
const sources = SOURCE_CONFIGS.map((source) => ({
  id: source.id,
  name: source.name,
  kind: source.kind,
  category: source.category,
  url: safeExternalHttpUrl(source.url),
  homepage: safeExternalHttpUrl(source.homepage ?? source.url)
}));
---

<SiteLayout lang="ja" title={t("ja", "nav.about")} currentPath="/about/">
  <AboutConsoleView lang="ja" updatedAt={updatedAt} sources={sources} />
</SiteLayout>
