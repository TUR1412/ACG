---
import "../styles/global.css";
import "../styles/sentinel-console.css";
import Icon from "../components/Icon.astro";
import { href } from "../lib/href";

const swHref = href("/sw.js");
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ACG Radar</title>
    <meta name="description" content="一个每小时自动更新的 ACG 资讯聚合小站（中日双语 UI）。" />
    <meta name="theme-color" content="#050816" />
    <link
      rel="search"
      type="application/opensearchdescription+xml"
      title="ACG Radar"
      href={href("/opensearch.xml")}
    />
    <link rel="manifest" href={href("/manifest.webmanifest")} />
    <link rel="icon" type="image/svg+xml" href={href("/favicon.svg")} />
  </head>
  <body class="sentinel-console-body">
    <main class="sentinel-console min-h-screen px-4 py-8 md:px-6 md:py-10">
      <section class="sentinel-shell">
        <div class="sentinel-panel p-6 md:p-8 xl:p-10">
          <div class="grid gap-8 xl:grid-cols-[minmax(0,1.15fr)_minmax(360px,0.85fr)] xl:items-end">
            <div class="space-y-6">
              <div class="acg-console-kicker-row">
                <span class="acg-console-kicker">SENTINEL CONSOLE</span>
                <span class="acg-console-status-pill">ENTRY GATE</span>
              </div>
              <div class="space-y-4">
                <h1 class="acg-console-title max-w-[10ch]">ACG Radar</h1>
                <p class="acg-console-copy max-w-[62ch]">
                  这是进入 ACG
                  信号总控台的入口页。选择语言后，你将进入一套以“扫描、聚焦、归档”为核心节奏的内容司令台，而不是传统资讯首页。
                </p>
              </div>
              <div class="acg-console-meta-grid md:max-w-3xl">
                <div class="acg-console-meta-card">
                  <span class="acg-console-meta-label">Mode</span>
                  <strong>Static Sentinel</strong>
                </div>
                <div class="acg-console-meta-card">
                  <span class="acg-console-meta-label">Update Cycle</span>
                  <strong>Hourly</strong>
                </div>
                <div class="acg-console-meta-card">
                  <span class="acg-console-meta-label">Deploy</span>
                  <strong>GitHub Pages</strong>
                </div>
                <div class="acg-console-meta-card">
                  <span class="acg-console-meta-label">Locale</span>
                  <strong>ZH / JA</strong>
                </div>
              </div>
            </div>

            <div class="acg-console-panel glass p-5 md:p-6">
              <div class="acg-console-panel-head">
                <div>
                  <h2>Channel Select</h2>
                  <p>选择主语言后进入对应镜像站点。</p>
                </div>
              </div>
              <div class="mt-4 grid gap-3">
                <a href="./zh/" class="acg-console-link-card clickable">
                  <div class="flex items-center justify-between gap-3">
                    <div>
                      <strong>中文站</strong>
                      <span>进入信号台 / 新闻动态 / 分类浏览</span>
                    </div>
                    <Icon name="chevron-right" size={18} />
                  </div>
                </a>
                <a href="./ja/" class="acg-console-link-card clickable">
                  <div class="flex items-center justify-between gap-3">
                    <div>
                      <strong>日本語サイト</strong>
                      <span>シグナル閲覧 / アーカイブ / 詳細読解</span>
                    </div>
                    <Icon name="chevron-right" size={18} />
                  </div>
                </a>
              </div>
              <div class="mt-6 acg-console-side-note">
                <div class="acg-console-side-head">
                  <span>Brief</span>
                  <span>Read before enter</span>
                </div>
                <p>
                  本站仅聚合标题、摘要、时间与原文入口，不转载全文；所有收藏、已读和偏好设置都保存在你的浏览器中。
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script is:inline define:vars={{ swHref }}>
      (() => {
        try {
          if (!("serviceWorker" in navigator)) return;
          const swUrl = swHref;
          window.addEventListener("load", () => {
            navigator.serviceWorker.register(swUrl).catch(() => {
              // ignore
            });
          });
        } catch {
          // ignore
        }
      })();
    </script>
  </body>
</html>
